# Investment Dashboard – Environment Variables
# Copy this file to .env and fill in your values.
# Never commit the .env file to version control.

# ---------------------------------------------------------------------------
# Flask API
# ---------------------------------------------------------------------------

# Port the Flask API listens on (default: 9000)
API_PORT=9000

# Optional API key for authentication.
# When set, all requests (except /health) must include the header:
#   X-API-Key: <your-key>
# Leave blank to disable authentication (suitable for local development only).
API_KEY=

# Rate limiting (requests per window, e.g. "200 per day;60 per minute")
# Overrides the built-in default when flask-limiter is installed.
RATELIMIT_DEFAULT=200 per day;60 per minute

# ---------------------------------------------------------------------------
# Sentiment / News
# ---------------------------------------------------------------------------

# NewsAPI key for real-time news headline sentiment.
# Get a free key at https://newsapi.org
# When blank, the system falls back to yfinance keyword-based sentiment.
NEWS_API_KEY=

# ---------------------------------------------------------------------------
# React dashboard
# ---------------------------------------------------------------------------

# Port the Vite dev server listens on (default: 3000)
DASHBOARD_PORT=3000
