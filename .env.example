# Investment Dashboard – Environment Variables
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ---------------------------------------------------------------------------
# Flask API
# ---------------------------------------------------------------------------

# Port the Flask REST API listens on (default: 9000)
API_PORT=9000

# ---------------------------------------------------------------------------
# React Dashboard
# ---------------------------------------------------------------------------

# Port the React dev server listens on (default: 3000)
DASHBOARD_PORT=3000

# ---------------------------------------------------------------------------
# Optional: NewsAPI (https://newsapi.org) for richer sentiment analysis.
# Leave blank to use the built-in yfinance keyword-based sentiment scorer.
# ---------------------------------------------------------------------------
# NEWS_API_KEY=your_newsapi_key_here
